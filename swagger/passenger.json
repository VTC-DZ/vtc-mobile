{
  "openapi": "3.1.0",
  "info": {
    "title": "VTC API",
    "description": "VTC platform API — account, passenger, driver, and admin surfaces.",
    "version": "0.1.0-SNAPSHOT"
  },
  "servers": [
    { "url": "http://localhost:8080", "description": "Generated server url" }
  ],
  "tags": [
    {
      "name": "Passenger Places",
      "description": "Search places, reverse-geocode, and resolve place details"
    },
    { "name": "Passenger Addresses", "description": "Manage saved addresses" },
    {
      "name": "Passenger Rides",
      "description": "Create rides, review offers, and manage active rides"
    }
  ],
  "paths": {
    "/api/passenger/addresses/{id}": {
      "put": {
        "tags": ["Passenger Addresses"],
        "summary": "Update address",
        "description": "Updates an existing saved address.",
        "operationId": "updateAddress",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateAddressRequest" }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Address updated",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/SavedAddressResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/SavedAddressResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/SavedAddressResponse"
                }
              }
            }
          },
          "404": {
            "description": "Address not found",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/SavedAddressResponse"
                }
              }
            }
          }
        },
        "security": [{ "bearerAuth": [] }]
      },
      "delete": {
        "tags": ["Passenger Addresses"],
        "summary": "Delete address",
        "description": "Deletes a saved address.",
        "operationId": "deleteAddress",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "204": { "description": "Address deleted" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Address not found" }
        },
        "security": [{ "bearerAuth": [] }]
      }
    },
    "/api/passenger/rides": {
      "post": {
        "tags": ["Passenger Rides"],
        "summary": "Create ride",
        "description": "Creates a new ride request with pickup/dropoff details.",
        "operationId": "createRide",
        "parameters": [
          {
            "name": "Idempotency-Key",
            "in": "header",
            "required": false,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateRideRequest" }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "description": "Ride request created",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/CreateRideResponse" }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/CreateRideResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/CreateRideResponse" }
              }
            }
          }
        },
        "security": [{ "bearerAuth": [] }]
      }
    },
    "/api/passenger/rides/{rideRequestId}/offers/{offerId}/refuse": {
      "post": {
        "tags": ["Passenger Rides"],
        "summary": "Refuse offer",
        "description": "Refuses a driver's offer for a ride request.",
        "operationId": "refuseOffer",
        "parameters": [
          {
            "name": "rideRequestId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "offerId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Offer refused",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/RefuseOfferResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/RefuseOfferResponse" }
              }
            }
          },
          "404": {
            "description": "Offer or ride request not found",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/RefuseOfferResponse" }
              }
            }
          }
        },
        "security": [{ "bearerAuth": [] }]
      }
    },
    "/api/passenger/rides/{rideRequestId}/offers/{offerId}/accept": {
      "post": {
        "tags": ["Passenger Rides"],
        "summary": "Accept offer",
        "description": "Accepts a driver's offer for a ride request.",
        "operationId": "acceptOffer",
        "parameters": [
          {
            "name": "rideRequestId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "offerId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "Idempotency-Key",
            "in": "header",
            "required": false,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Offer accepted",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/AcceptOfferResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/AcceptOfferResponse" }
              }
            }
          },
          "404": {
            "description": "Offer or ride request not found",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/AcceptOfferResponse" }
              }
            }
          }
        },
        "security": [{ "bearerAuth": [] }]
      }
    },
    "/api/passenger/rides/{rideRequestId}/cancel": {
      "post": {
        "tags": ["Passenger Rides"],
        "summary": "Cancel ride",
        "description": "Cancels a ride request from the passenger's side.",
        "operationId": "cancel",
        "parameters": [
          {
            "name": "rideRequestId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "Idempotency-Key",
            "in": "header",
            "required": false,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CancelRideRequest" }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Ride cancelled",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/CancelRideResponse" }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/CancelRideResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/CancelRideResponse" }
              }
            }
          },
          "404": {
            "description": "Ride not found",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/CancelRideResponse" }
              }
            }
          }
        },
        "security": [{ "bearerAuth": [] }]
      }
    },
    "/api/passenger/addresses": {
      "get": {
        "tags": ["Passenger Addresses"],
        "summary": "List saved addresses",
        "description": "Returns all saved addresses for the authenticated passenger.",
        "operationId": "listAddresses",
        "responses": {
          "200": {
            "description": "Address list",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/SavedAddressListResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/SavedAddressListResponse"
                }
              }
            }
          }
        },
        "security": [{ "bearerAuth": [] }]
      },
      "post": {
        "tags": ["Passenger Addresses"],
        "summary": "Add address",
        "description": "Saves a new address for the authenticated passenger.",
        "operationId": "addAddress",
        "parameters": [
          {
            "name": "replace",
            "in": "query",
            "required": false,
            "schema": { "type": "boolean", "default": false }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AddAddressRequest" }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Address created",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/SavedAddressResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/SavedAddressResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/SavedAddressResponse"
                }
              }
            }
          }
        },
        "security": [{ "bearerAuth": [] }]
      }
    },
    "/api/passenger/rides/{rideRequestId}": {
      "get": {
        "tags": ["Passenger Rides"],
        "summary": "Get ride detail",
        "description": "Returns detailed information about a specific ride request.",
        "operationId": "getRide",
        "parameters": [
          {
            "name": "rideRequestId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Ride detail",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/RideDetailResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/RideDetailResponse" }
              }
            }
          },
          "404": {
            "description": "Ride not found",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/RideDetailResponse" }
              }
            }
          }
        },
        "security": [{ "bearerAuth": [] }]
      }
    },
    "/api/passenger/rides/{rideRequestId}/offers": {
      "get": {
        "tags": ["Passenger Rides"],
        "summary": "List offers",
        "description": "Returns all offers for a ride request.",
        "operationId": "listOffers",
        "parameters": [
          {
            "name": "rideRequestId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Offer list",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/OfferListResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/OfferListResponse" }
              }
            }
          },
          "404": {
            "description": "Ride request not found",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/OfferListResponse" }
              }
            }
          }
        },
        "security": [{ "bearerAuth": [] }]
      }
    },
    "/api/passenger/rides/active": {
      "get": {
        "tags": ["Passenger Rides"],
        "summary": "Get active ride",
        "description": "Returns the passenger's currently active ride, if any.",
        "operationId": "getActive",
        "responses": {
          "200": {
            "description": "Active ride found",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/ActiveRideResponse" }
              }
            }
          },
          "204": {
            "description": "No active ride",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/ActiveRideResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/ActiveRideResponse" }
              }
            }
          }
        },
        "security": [{ "bearerAuth": [] }]
      }
    },
    "/api/passenger/places/{placeId}": {
      "get": {
        "tags": ["Passenger Places"],
        "summary": "Resolve place",
        "description": "Returns details for a specific place by ID.",
        "operationId": "resolve",
        "parameters": [
          {
            "name": "placeId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "minLength": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "Place detail",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/PlaceDetailResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/PlaceDetailResponse" }
              }
            }
          },
          "404": {
            "description": "Place not found",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/PlaceDetailResponse" }
              }
            }
          }
        },
        "security": [{ "bearerAuth": [] }]
      }
    },
    "/api/passenger/places/search": {
      "get": {
        "tags": ["Passenger Places"],
        "summary": "Search places",
        "description": "Full-text place search with optional location bias.",
        "operationId": "search",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "maxLength": 200, "minLength": 2 }
          },
          {
            "name": "sessionToken",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "bias",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "pattern": "^-?\\d+\\.?\\d*,-?\\d+\\.?\\d*$"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/PlaceSearchResponse" }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/PlaceSearchResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/PlaceSearchResponse" }
              }
            }
          }
        },
        "security": [{ "bearerAuth": [] }]
      }
    },
    "/api/passenger/places/reverse-geocode": {
      "get": {
        "tags": ["Passenger Places"],
        "summary": "Reverse geocode",
        "description": "Resolves coordinates to a place description.",
        "operationId": "reverseGeocode",
        "parameters": [
          {
            "name": "lat",
            "in": "query",
            "required": true,
            "schema": { "type": "number", "maximum": 90.0, "minimum": -90.0 }
          },
          {
            "name": "lng",
            "in": "query",
            "required": true,
            "schema": { "type": "number", "maximum": 180.0, "minimum": -180.0 }
          }
        ],
        "responses": {
          "200": {
            "description": "Place detail",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/PlaceDetailResponse" }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/PlaceDetailResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/PlaceDetailResponse" }
              }
            }
          }
        },
        "security": [{ "bearerAuth": [] }]
      }
    }
  },
  "components": {
    "schemas": {
      "UpdateAddressRequest": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["HOME", "WORK", "OTHER"] },
          "label": { "type": "string", "maxLength": 100, "minLength": 0 },
          "address": { "type": "string", "maxLength": 1024, "minLength": 0 },
          "latitude": {
            "type": "number",
            "format": "double",
            "maximum": 90.0,
            "minimum": -90.0
          },
          "longitude": {
            "type": "number",
            "format": "double",
            "maximum": 180.0,
            "minimum": -180.0
          },
          "building": { "type": "string", "maxLength": 100, "minLength": 0 },
          "floor": { "type": "string", "maxLength": 50, "minLength": 0 },
          "door": { "type": "string", "maxLength": 50, "minLength": 0 },
          "description": { "type": "string", "maxLength": 1024, "minLength": 0 }
        }
      },
      "SavedAddressResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "type": { "type": "string", "enum": ["HOME", "WORK", "OTHER"] },
          "label": { "type": "string" },
          "address": { "type": "string" },
          "latitude": { "type": "number", "format": "double" },
          "longitude": { "type": "number", "format": "double" },
          "building": { "type": "string" },
          "floor": { "type": "string" },
          "door": { "type": "string" },
          "description": { "type": "string" }
        }
      },
      "CoordinatePoint": {
        "type": "object",
        "properties": {
          "lat": { "type": "number", "maximum": 90, "minimum": -90 },
          "lng": { "type": "number", "maximum": 180, "minimum": -180 },
          "address": { "type": "string", "maxLength": 500, "minLength": 0 }
        },
        "required": ["address", "lat", "lng"]
      },
      "CreateRideRequest": {
        "type": "object",
        "properties": {
          "pickup": { "$ref": "#/components/schemas/CoordinatePoint" },
          "dropoff": { "$ref": "#/components/schemas/CoordinatePoint" },
          "serviceType": { "type": "string", "enum": ["RIDE", "DELIVERY"] },
          "vehicleCategory": {
            "type": "string",
            "enum": ["CAR", "MOTORCYCLE", "VAN"]
          },
          "femaleOnly": { "type": "boolean" },
          "proposedFare": {
            "type": "integer",
            "format": "int64",
            "maximum": 50000,
            "minimum": 100
          },
          "recipientName": { "type": "string" },
          "recipientPhone": { "type": "string" },
          "packageNote": { "type": "string" }
        },
        "required": [
          "dropoff",
          "femaleOnly",
          "pickup",
          "proposedFare",
          "serviceType"
        ]
      },
      "CreateRideResponse": {
        "type": "object",
        "properties": {
          "rideRequestId": { "type": "string", "format": "uuid" },
          "state": {
            "type": "string",
            "enum": ["REQUESTED", "NEGOTIATING", "ACCEPTED", "CANCELLED"]
          },
          "proposedFare": { "type": "integer", "format": "int64" },
          "expiresAt": { "type": "string", "format": "date-time" },
          "broadcastDriverCount": { "type": "integer", "format": "int32" }
        }
      },
      "RefuseOfferResponse": {
        "type": "object",
        "properties": {
          "offerId": { "type": "string", "format": "uuid" },
          "status": {
            "type": "string",
            "enum": [
              "ACTIVE",
              "ACCEPTED",
              "REJECTED",
              "COUNTERED",
              "EXPIRED",
              "WITHDRAWN"
            ]
          }
        }
      },
      "AcceptOfferResponse": {
        "type": "object",
        "properties": {
          "rideId": { "type": "string", "format": "uuid" },
          "state": {
            "type": "string",
            "enum": [
              "ACCEPTED",
              "ARRIVED",
              "IN_PROGRESS",
              "COMPLETED",
              "CANCELLED"
            ]
          },
          "finalFare": { "type": "integer", "format": "int64" }
        }
      },
      "CancelRideRequest": {
        "type": "object",
        "properties": {
          "reason": {
            "type": "string",
            "enum": [
              "PASSENGER_CHANGED_MIND",
              "PASSENGER_NO_SHOW",
              "DRIVER_TOO_FAR",
              "DRIVER_VEHICLE_ISSUE",
              "ADMIN_FORCED",
              "SYSTEM_TIMEOUT",
              "SYSTEM_NO_DRIVERS"
            ]
          },
          "note": { "type": "string", "maxLength": 500, "minLength": 0 }
        },
        "required": ["reason"]
      },
      "CancelRideResponse": {
        "type": "object",
        "properties": {
          "state": {
            "type": "string",
            "enum": ["REQUESTED", "NEGOTIATING", "ACCEPTED", "CANCELLED"]
          },
          "cancelledAt": { "type": "string", "format": "date-time" }
        }
      },
      "AddAddressRequest": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["HOME", "WORK", "OTHER"] },
          "label": { "type": "string", "maxLength": 100, "minLength": 0 },
          "address": { "type": "string", "maxLength": 1024, "minLength": 0 },
          "latitude": {
            "type": "number",
            "format": "double",
            "maximum": 90.0,
            "minimum": -90.0
          },
          "longitude": {
            "type": "number",
            "format": "double",
            "maximum": 180.0,
            "minimum": -180.0
          },
          "building": { "type": "string", "maxLength": 100, "minLength": 0 },
          "floor": { "type": "string", "maxLength": 50, "minLength": 0 },
          "door": { "type": "string", "maxLength": 50, "minLength": 0 },
          "description": { "type": "string", "maxLength": 1024, "minLength": 0 }
        },
        "required": ["address", "label", "type"]
      },
      "Coordinate": {
        "type": "object",
        "properties": {
          "lat": { "type": "number" },
          "lng": { "type": "number" }
        }
      },
      "DriverInRide": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "fullName": { "type": "string" },
          "phone": { "type": "string" },
          "vehicleModel": { "type": "string" },
          "vehiclePlate": { "type": "string" },
          "currentPosition": { "$ref": "#/components/schemas/Coordinate" }
        }
      },
